<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <title>ระบบสมัครเข้าชมรม</title>
</head>
<body>
    <div class="login-container">
        <h2>User</h2>
            <input type="text" size="50" id="User_ID" name="User_ID" required="true"/>
        <h2>Password</h2>
            <input type="password" size="50" id="userpassword" name="userpassword" required="true"/>
            <div><button class="btn-login">Login</button></div>
    </div>
</body>
</html>




<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <title>ระบบสมัครเข้าชมรม</title>
</head>
<body>
    <div class="register-container">
        <h2>Register</h2>
        <h3>ชื่อ</h3>
            <input type="text" size="100" id="First_Name" name="First_Name" required="true"/>
        <h3>นามสกุล</h3>
            <input type="text" size="100" id="Last_Name" name="Last_Name" required="true"/>
        <h3>เบอร์โทร</h3>
            <input type="text" size="50" id="Phone" name="Phone" required="true"/>
        <h3>อีเมล</h3>
            <input type="email" size="50" id="Email" name="Email" required="true"/>
            <div><button class="btn-reg">Register</button></div>
    </div>
</body>
</html>









